{
  "hosting": [
    {
      "target": "trivia",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "**/node_modules/**",
        "jeopardy/**"
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|html)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ]
    },
    {
      "target": "jeopardy",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/jeopardy/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|html)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ]
    }
  ]
}